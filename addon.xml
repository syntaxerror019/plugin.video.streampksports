<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.streampkports"
       name="StreamPK Sports"
       version="1.0.0"
       provider-name="Miles Hilliard">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Watch Live Sports, courtesy of streamed.pk</summary>
        <description lang="en_GB">Browse and watch live sports matches from Streamed API.</description>
        <platform>all</platform>
        <language>en</language>
        <license>GPL-3.0</license>
        <forum></forum>
        <website>https://www.mileshilliard.com</website>
        <source></source>
        <assets>
            <icon>icon.png</icon>
            <fanart>icon.png</fanart>
        </assets>
    </extension>
</addon>
<import addon="script.module.requests" version="2.25.0"/>